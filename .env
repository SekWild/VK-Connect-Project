APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

FRONTEND_VK_SUCCESS_URL=http://localhost:3000/integrations/vk/success
FRONTEND_VK_ERROR_URL=http://localhost:3000/integrations/vk/error

VK_CLIENT_ID=***VK_CLIENT_ID***
VK_CLIENT_SECRET=***VK_SECRET_KEY***

VK_REDIRECT_URI=https://cggplbts-8000.euw.devtunnels.ms/auth/vk/callback

VK_SCOPES="vkid.personal_info"

VK_OAUTH_AUTHORIZE_URL=https://id.vk.com/authorize
VK_OAUTH_TOKEN_URL=https://id.vk.com/oauth2/auth
VK_OAUTH_USER_INFO_URL=https://id.vk.com/oauth2/user_info

VK_API_BASE_URL=https://api.vk.com/method
VK_API_VERSION=5.199

VK_RATE_LIMIT_REQUESTS_PER_SECOND=2

AUTH_CODE_STORAGE_JSON_PATH=data/auth_code_storage.json
OAUTH_STATE_STORAGE_JSON_PATH=data/oauth_state_storage.json

OAUTH_STATE_TTL_SECONDS=600
ACCESS_TOKEN_REFRESH_BEFORE_EXPIRE_SECONDS=300

HTTP_TIMEOUT_SECONDS=15

TOKEN_ENCRYPTION_KEY=test_token_encryption_key_replace_me
